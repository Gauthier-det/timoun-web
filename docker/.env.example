# PostgreSQL
POSTGRES_USER=strapi
# OBLIGATOIRE en prod — generer avec : openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=timoun_db

# Strapi secrets — generer chaque valeur avec : openssl rand -base64 32
APP_KEYS=cle1base64,cle2base64,cle3base64,cle4base64
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# URL publique de l'API utilisee par le build du frontend
# Dev local : http://localhost:1337
# Prod (avec Caddy) : laisser vide pour utiliser des URLs relatives
#                     (le front et l'API sont sur le meme domaine)
VITE_API_URL=

# Origines autorisees pour CORS cote Strapi (liste separee par des virgules)
# En prod avec Caddy (meme domaine), CORS n'est pas declenche mais on liste
# le domaine au cas ou : https://votre-domaine.fr
CORS_ORIGINS=https://votre-domaine.fr

# === Variables prod (utilisees uniquement avec docker-compose.prod.yml) ===
# Domaine pour lequel Caddy obtient un certificat TLS via Let's Encrypt
DOMAIN=votre-domaine.fr
# Adresse email recue par Let's Encrypt (notifications expiration cert)
ACME_EMAIL=admin@votre-domaine.fr
